<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_connection_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/connection_status_disconnected"
            android:textSize="12sp"
            android:textColor="@color/failure"
            android:drawableStart="@drawable/ic_circle_red"
            android:drawablePadding="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp" />

        <!-- 1. Card: ملف الراوتر -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOnSurface"
            app:strokeWidth="0.5dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/select_router"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:drawableEnd="@drawable/ic_router"
                    android:drawablePadding="8dp"
                    android:layout_gravity="end"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinner_router"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:popupBackground="?attr/colorSurface" />

                <TextView
                    android:id="@+id/tv_router_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.7"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2. Card: إعدادات التوليد (حقول نصية مباشرة) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOnSurface"
            app:strokeWidth="0.5dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/generation_settings"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:drawableEnd="@drawable/ic_settings"
                    android:drawablePadding="8dp"
                    android:layout_gravity="end"
                    android:layout_marginBottom="16dp" />

                <!-- الطول الكلي والبادئة في صف واحد -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                          <!-- البادئة -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Input"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:hint="@string/prefix">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_prefix"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:text="RT"
                            android:textColor="?attr/colorOnSurface"
                            android:maxLength="8" />
                    </com.google.android.material.textfield.TextInputLayout>              
                    
                    <!-- الطول -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Input"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:hint="@string/length">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_length"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="7"
                            android:textColor="?attr/colorOnSurface"
                            android:maxLength="2" />
                    </com.google.android.material.textfield.TextInputLayout>                    
                </LinearLayout>

                <!-- الأحرف المستخدمة -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="@string/charset_label">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_charset"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:text="0123456789"
                        android:textColor="?attr/colorOnSurface" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- عدد المحاولات -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/count">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="100"
                        android:textColor="?attr/colorOnSurface"
                        android:maxLength="4" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3. Card: خيارات متقدمة -->
<com.google.android.material.card.MaterialCardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOnSurface"
    app:strokeWidth="0.5dp"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/advanced_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/advanced"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurface"
                android:drawableEnd="@drawable/ic_wrench"
                android:drawablePadding="8dp"
                android:layout_gravity="end" />

            <TextView
                android:id="@+id/tv_advanced_toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurface" />
        </LinearLayout>

        <!-- Content -->
        <LinearLayout
            android:id="@+id/advanced_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            android:visibility="gone">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_skip_tested"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/skip_tested"
                android:checked="true" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_stop_on_success"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/stop_on_success"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

        <!-- 4. الإحصائيات -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOnSurface"
                app:strokeWidth="0.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_failed_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/failure" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_failure"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOnSurface"
                app:strokeWidth="0.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_success_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_success"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOnSurface"
                app:strokeWidth="0.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_sent_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_tested"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- التقدم -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="0%"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurface" />

            <ProgressBar
                android:id="@+id/progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:max="100"
                android:progress="0" />
        </LinearLayout>

        <!-- أزرار التحكم -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_test"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="0.5"
                android:text="@string/start_test"
                style="@style/Widget.Button.Primary"
                android:textStyle="bold"
                android:layout_marginEnd="4dp" />
                
                <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_stop_test"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="0.5"
                android:text="@string/stop_test"
                style="@style/Widget.Button.Danger"
                app:icon="@drawable/ic_stop"
                android:enabled="false" />
        </LinearLayout>

        <!-- حفظ الناجح -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_successful"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            tools:text="@string/save_successful"
            android:textSize="14sp"
            style="@style/Widget.Button.Secondary"
            app:icon="@drawable/ic_save"
            android:layout_marginBottom="12dp" />

        <!-- 5. سجل العمليات -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOnSurface"
            app:strokeWidth="0.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:gravity="center_vertical"
                    android:background="?android:attr/colorBackground">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_copy"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/copy"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurface"
                        app:strokeColor="?attr/colorOnSurface"
                        app:strokeWidth="0.5dp"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clear_log_extra"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/clear_log"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurface"
                        app:strokeColor="?attr/colorOnSurface"
                        app:strokeWidth="0.5dp" />
                        
                        <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/operation_log_label"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:drawableEnd="@drawable/ic_clipboard"
                        android:drawablePadding="8dp"
                        android:layout_gravity="end" />
                </LinearLayout>

                <!-- Log Content -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_log"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:padding="8dp"
                    android:clipToPadding="false" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
